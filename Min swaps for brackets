def minimumSwaps(s):
    balance = 0
    swaps = 0
    imbalance = 0
    
    for ch in s:
        if ch == '[':
            balance += 1
            
            if imbalance > 0:
                swaps += imbalance
                imbalance -= 1
                
        else:  # ch == ']'
            balance -= 1
            
            if balance < 0:
                imbalance += 1
                balance = 0
                
    return swaps

