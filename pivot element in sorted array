def find_pivot(arr):
    low = 0
    high = len(arr) - 1
    
    # If array is not rotated
    if arr[low] <= arr[high]:
        return high   # last element is pivot
    
    while low <= high:
        mid = (low + high) // 2
        
        # Check if mid is pivot
        if mid < high and arr[mid] > arr[mid + 1]:
            return mid
        
        if mid > low and arr[mid] < arr[mid - 1]:
            return mid - 1
        
        # Decide which side to search
        if arr[mid] >= arr[low]:
            low = mid + 1
        else:
            high = mid - 1
    
    return -1
