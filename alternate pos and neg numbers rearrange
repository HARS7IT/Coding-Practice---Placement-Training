class Solution:
    def rearrange(self, arr):
        pos = []
        neg = []
        
        # Separate positives and negatives
        for num in arr:
            if num >= 0:   # 0 is positive
                pos.append(num)
            else:
                neg.append(num)
        
        i = j = 0
        result = []
        
        # Alternate starting with positive
        while i < len(pos) and j < len(neg):
            result.append(pos[i])
            result.append(neg[j])
            i += 1
            j += 1
        
        # Append remaining positives
        while i < len(pos):
            result.append(pos[i])
            i += 1
        
        # Append remaining negatives
        while j < len(neg):
            result.append(neg[j])
            j += 1
        
        return result
