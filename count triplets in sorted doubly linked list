class Solution:
    def countTriplets(self, head, x):
        count = 0
        
        ptr1 = head
        
        while ptr1:
            ptr2 = ptr1.next
            
            while ptr2:
                ptr3 = ptr2.next
                
                while ptr3:
                    if ptr1.data + ptr2.data + ptr3.data == x:
                        count += 1
                    ptr3 = ptr3.next
                
                ptr2 = ptr2.next
            
            ptr1 = ptr1.next
        
        return count